Program {
  Import(package="aivectra" path="src/AiVectra/src/lib.aos")
  Export(name=start)

  Let(name=start) {
    Fn(params=args) {
      Block {
        Let(name=handle) { Call(target=window) { Lit(value="Hello AiVectra") } }
        Call(target=rect) { Var(name=handle) }
        Call(target=text) { Var(name=handle) Lit(value="Hello from AiVectra") }
        Call(target=sys.ui.waitFrame) { Var(name=handle) }
        Return { Lit(value=0) }
      }
    }
  }
}

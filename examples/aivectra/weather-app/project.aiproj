Program {
  Project(
    name="WeatherApp"
    entryFile="src/app.aos"
    entryExport="start"
    runTool="aivectra"
  ) {
    Include(name="aivectra" version="0.0.1-beta.15")
    Include(name="vectra-ui" version="0.0.1-alpha.26")
    Include(name="std-http")
    Include(name="std-storage")
    Include(name="target-aios-gui" version="0.0.1-alpha.1")
  }
}
